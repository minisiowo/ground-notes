<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="QuickNotesTxt.Views.AiSettingsWindow"
        Title="AI Settings"
        Width="560"
        Height="472"
        MinWidth="480"
        MinHeight="320"
        CanResize="False"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        KeyDown="OnWindowKeyDown"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0"
            Classes="titleBarSurface"
            BorderThickness="0,0,0,1"
            PointerPressed="OnTitleBarPointerPressed">
      <Grid ColumnDefinitions="*,Auto">
        <Border Grid.Column="0"
                Background="Transparent"
                Padding="12,6">
          <TextBlock Classes="titleBarText" Text="AI Settings" VerticalAlignment="Center" />
        </Border>
        <Button Grid.Column="1"
                Classes="titleBarButton titleBarCloseButton"
                Click="OnCancelClick"
                Content="X"
                Width="42"
                Height="30" />
      </Grid>
    </Border>

    <Border Grid.Row="1" Classes="sectionSurface" Margin="12" Padding="14,14,14,18" BorderThickness="1">
      <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto">
        <CheckBox x:Name="AiEnabledCheckBox"
                  Content="Enable AI actions"
                  IsChecked="True" />

        <StackPanel Grid.Row="1" Margin="0,12,0,0" Spacing="6">
          <TextBlock Text="OpenAI API key" />
          <TextBox x:Name="ApiKeyTextBox"
                   PasswordChar="*"
                   Watermark="sk-..." />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,12,0,0" Spacing="6">
          <TextBlock Text="Default model" />
          <TextBox x:Name="DefaultModelTextBox"
                   Watermark="gpt-4.1-mini" />
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,12,0,0" Spacing="6">
          <TextBlock Text="OpenAI Project ID (optional)" />
          <TextBox x:Name="ProjectIdTextBox"
                   Watermark="proj_..." />
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,12,0,0" Spacing="6">
          <TextBlock Text="OpenAI Organization ID (optional)" />
          <TextBox x:Name="OrganizationIdTextBox"
                   Watermark="org_..." />
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="0,12,0,0" Spacing="6">
          <TextBlock Text="Custom prompts folder" />
          <TextBlock x:Name="PromptsFolderTextBlock"
                     Classes="metaText"
                     TextWrapping="Wrap" />
        </StackPanel>

        <TextBlock Grid.Row="6"
                   Classes="metaText"
                   Margin="0,12,0,0"
                   Text="Built-in prompts load from Assets. Add your own prompt JSON files to the custom prompts folder inside your notes directory. If your API key belongs to a specific OpenAI project, set Project ID here too."
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="7"
                    Margin="0,20,0,4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
          <Button Classes="secondaryButton" Content="Cancel" Click="OnCancelClick" />
          <Button x:Name="SaveButton" Content="Save" Click="OnSaveClick" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
