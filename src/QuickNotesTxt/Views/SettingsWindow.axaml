<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="QuickNotesTxt.Views.SettingsWindow"
        Title="Settings"
        Width="620"
        Height="640"
        MinWidth="620"
        MinHeight="600"
        CanResize="False"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        KeyDown="OnWindowKeyDown"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*,Auto">
    <!-- Title Bar -->
    <Border Grid.Row="0"
            Classes="titleBarSurface"
            BorderThickness="0,0,0,1"
            PointerPressed="OnTitleBarPointerPressed">
      <Grid ColumnDefinitions="*,Auto">
        <Border Grid.Column="0"
                Background="Transparent"
                Padding="16,10">
          <TextBlock Classes="titleBarText" Text="Settings" VerticalAlignment="Center" />
        </Border>
        <Button Grid.Column="1"
                Classes="titleBarButton titleBarCloseButton"
                Click="OnCancelClick"
                Content="X"
                Width="46"
                Height="34" />
      </Grid>
    </Border>

    <!-- Content -->
    <TabControl Grid.Row="1" Margin="0">
      <!-- Tab 1: Appearance -->
      <TabItem Header="Appearance">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="24,16" Spacing="24">
            <!-- General Section -->
            <StackPanel Spacing="4">
              <TextBlock Classes="settingsHeader" Text="General" />
              
              <Border Classes="settingsCard">
                <Grid ColumnDefinitions="*, Auto">
                  <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock Classes="settingsLabel" Text="App Theme" />
                    <TextBlock Classes="settingsDescription" Text="Choose between Light and Dark mode." />
                  </StackPanel>
                  <ComboBox Grid.Column="1" x:Name="ThemeComboBox" Width="140" SelectionChanged="OnAppearanceSelectionChanged" />
                </Grid>
              </Border>

              <Border Classes="settingsCard">
                <Grid ColumnDefinitions="*, Auto">
                  <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock Classes="settingsLabel" Text="UI Font Size" />
                    <TextBlock Classes="settingsDescription" Text="Scaling for menus and sidebar." />
                  </StackPanel>
                  <ComboBox Grid.Column="1" x:Name="UiFontSizeComboBox" Width="140" SelectionChanged="OnAppearanceSelectionChanged" />
                </Grid>
              </Border>

              <Border Classes="settingsCard">
                <Grid ColumnDefinitions="*, Auto">
                  <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock Classes="settingsLabel" Text="Editor Font Size" />
                    <TextBlock Classes="settingsDescription" Text="Size for the markdown text editor." />
                  </StackPanel>
                  <ComboBox Grid.Column="1" x:Name="EditorFontSizeComboBox" Width="140" SelectionChanged="OnAppearanceSelectionChanged" />
                </Grid>
              </Border>
            </StackPanel>

            <!-- Typography Section -->
            <StackPanel Spacing="4">
              <TextBlock Classes="settingsHeader" Text="Typography" />

              <Border Classes="settingsCard">
                <Grid ColumnDefinitions="*, Auto, Auto">
                  <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock Classes="settingsLabel" Text="Sidebar Font" />
                    <TextBlock Classes="settingsDescription" Text="Font used in the notes list." />
                  </StackPanel>
                  <ComboBox Grid.Column="1" x:Name="SidebarFontFamilyComboBox" Width="180" Margin="12,0,0,0" SelectionChanged="OnSidebarFontFamilySelectionChanged" />
                  <ComboBox Grid.Column="2" x:Name="SidebarFontVariantComboBox" Width="140" Margin="8,0,0,0" SelectionChanged="OnAppearanceSelectionChanged" />
                </Grid>
              </Border>

              <Border Classes="settingsCard">
                <Grid ColumnDefinitions="*, Auto, Auto">
                  <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock Classes="settingsLabel" Text="Editor Font" />
                    <TextBlock Classes="settingsDescription" Text="Main writing font." />
                  </StackPanel>
                  <ComboBox Grid.Column="1" x:Name="FontFamilyComboBox" Width="180" Margin="12,0,0,0" SelectionChanged="OnFontFamilySelectionChanged" />
                  <ComboBox Grid.Column="2" x:Name="FontVariantComboBox" Width="140" Margin="8,0,0,0" SelectionChanged="OnAppearanceSelectionChanged" />
                </Grid>
              </Border>

              <Border Classes="settingsCard">
                <Grid ColumnDefinitions="*, Auto, Auto">
                  <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock Classes="settingsLabel" Text="Code Block Font" />
                    <TextBlock Classes="settingsDescription" Text="Monospaced font for code blocks." />
                  </StackPanel>
                  <ComboBox Grid.Column="1" x:Name="CodeFontFamilyComboBox" Width="180" Margin="12,0,0,0" SelectionChanged="OnCodeFontFamilySelectionChanged" />
                  <ComboBox Grid.Column="2" x:Name="CodeFontVariantComboBox" Width="140" Margin="8,0,0,0" SelectionChanged="OnAppearanceSelectionChanged" />
                </Grid>
              </Border>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Tab 2: AI Actions -->
      <TabItem Header="AI Actions">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="24,16" Spacing="24">
            <StackPanel Spacing="4">
              <TextBlock Classes="settingsHeader" Text="AI Integration" />
              
              <Border Classes="settingsCard">
                <Grid ColumnDefinitions="*, Auto">
                  <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock Classes="settingsLabel" Text="Enable AI features" />
                    <TextBlock Classes="settingsDescription" Text="Unlock context actions like summarization and translation." />
                  </StackPanel>
                  <ToggleSwitch Grid.Column="1" x:Name="AiEnabledToggle" IsChecked="True" OnContent="" OffContent="" IsCheckedChanged="OnAppearanceSelectionChanged" />
                </Grid>
              </Border>

              <Border IsEnabled="{Binding #AiEnabledToggle.IsChecked}" Classes="settingsCard">
                <Grid ColumnDefinitions="*, 330">
                  <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock Classes="settingsLabel" Text="OpenAI API Key" />
                    <TextBlock Classes="settingsDescription" Text="Keys are stored locally and never shared." />
                  </StackPanel>
                  <TextBox Grid.Column="1" x:Name="ApiKeyTextBox" PasswordChar="*" Watermark="sk-..." TextChanged="OnAppearanceSelectionChanged" />
                </Grid>
              </Border>

              <Border IsEnabled="{Binding #AiEnabledToggle.IsChecked}" Classes="settingsCard">
                <Grid ColumnDefinitions="*, 330">
                  <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock Classes="settingsLabel" Text="Model ID" />
                    <TextBlock Classes="settingsDescription" Text="E.g., gpt-5.4-mini" />
                  </StackPanel>
                  <TextBox Grid.Column="1" x:Name="DefaultModelTextBox" Watermark="gpt-5.4-mini" TextChanged="OnAppearanceSelectionChanged" />
                </Grid>
              </Border>

              <Border IsEnabled="{Binding #AiEnabledToggle.IsChecked}" Classes="settingsCard">
                <Grid ColumnDefinitions="*, 330">
                  <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock Classes="settingsLabel" Text="Project ID" />
                    <TextBlock Classes="settingsDescription" Text="Optional OpenAI project identifier." />
                  </StackPanel>
                  <TextBox Grid.Column="1" x:Name="ProjectIdTextBox" Watermark="proj_..." TextChanged="OnAppearanceSelectionChanged" />
                </Grid>
              </Border>

              <Border IsEnabled="{Binding #AiEnabledToggle.IsChecked}" Classes="settingsCard">
                <Grid ColumnDefinitions="*, 330">
                  <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock Classes="settingsLabel" Text="Organization ID" />
                    <TextBlock Classes="settingsDescription" Text="Optional OpenAI organization identifier." />
                  </StackPanel>
                  <TextBox Grid.Column="1" x:Name="OrganizationIdTextBox" Watermark="org_..." TextChanged="OnAppearanceSelectionChanged" />
                </Grid>
              </Border>

              <Border Classes="settingsCard" Margin="0,12,0,0">
                <StackPanel Spacing="8">
                  <TextBlock Classes="settingsLabel" Text="Custom Prompts Folder" />
                  <TextBlock x:Name="PromptsFolderTextBlock" Classes="metaText" TextWrapping="Wrap" />
                  <TextBlock Classes="settingsDescription" Text="Add .json files here to define your own AI actions. Folder is located inside your current notes directory." />
                </StackPanel>
              </Border>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>

    <!-- Actions -->
    <Border Grid.Row="2"
            Padding="24,16"
            BorderBrush="{DynamicResource BorderBrushBase}"
            BorderThickness="0,1,0,0">
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="12">
        <Button Classes="secondaryButton" Content="Cancel" Click="OnCancelClick" Width="100" />
        <Button x:Name="SaveButton" Content="Save" Click="OnSaveClick" Width="100" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
