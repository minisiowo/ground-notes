<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="QuickNotesTxt.Views.ConfirmDeleteWindow"
        Title="Confirm Delete"
        Width="420"
        Height="170"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <Border Classes="sectionSurface" Margin="12" Padding="14" BorderThickness="1">
    <Grid RowDefinitions="Auto,*,Auto">
      <TextBlock Text="Delete note?" FontSize="14" FontWeight="SemiBold" />
      <TextBlock Grid.Row="1"
                 Classes="metaText"
                 Margin="0,10,0,0"
                 TextWrapping="Wrap"
                 Text="{Binding Message}" />
      <StackPanel Grid.Row="2"
                  Margin="0,14,0,0"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="8">
        <Button Classes="secondaryButton" Content="Cancel" Click="OnCancelClick" />
        <Button Content="Delete" Click="OnDeleteClick" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
