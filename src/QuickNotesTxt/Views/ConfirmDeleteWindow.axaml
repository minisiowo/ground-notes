<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="QuickNotesTxt.Views.ConfirmDeleteWindow"
        Title="Confirm Delete"
        Width="420"
        Height="200"
        CanResize="False"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0"
            Classes="titleBarSurface"
            BorderThickness="0,0,0,1"
            PointerPressed="OnTitleBarPointerPressed">
      <Grid ColumnDefinitions="*,Auto">
        <Border Grid.Column="0"
                Background="Transparent"
                Padding="12,6">
          <TextBlock Classes="titleBarText" Text="Confirm Delete" VerticalAlignment="Center" />
        </Border>
        <Button Grid.Column="1"
                Classes="titleBarButton titleBarCloseButton"
                Click="OnCancelClick"
                Content="X"
                Width="42"
                Height="30" />
      </Grid>
    </Border>

    <Border Grid.Row="1" Classes="sectionSurface" Margin="12" Padding="14" BorderThickness="1">
      <Grid RowDefinitions="Auto,*,Auto">
        <TextBlock Text="Delete note?" FontSize="{DynamicResource AppFontSizeLarge}" FontWeight="SemiBold" />
        <TextBlock Grid.Row="1"
                   Classes="metaText"
                   Margin="0,10,0,0"
                   TextWrapping="Wrap"
                   Text="{Binding Message}" />
        <StackPanel Grid.Row="2"
                    Margin="0,14,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
          <Button Classes="secondaryButton" Content="Cancel" Click="OnCancelClick" />
          <Button Content="Delete" Click="OnDeleteClick" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
