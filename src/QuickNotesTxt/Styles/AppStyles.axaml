<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <FontFamily x:Key="TerminalFont">Cascadia Mono, Cascadia Code, Consolas, Menlo, Monaco, Monospace</FontFamily>

    <SolidColorBrush x:Key="AppBackgroundBrush">#111417</SolidColorBrush>
    <SolidColorBrush x:Key="PaneBackgroundBrush">#171C21</SolidColorBrush>
    <SolidColorBrush x:Key="SurfaceBackgroundBrush">#111417</SolidColorBrush>
    <SolidColorBrush x:Key="SurfaceHoverBrush">#111417</SolidColorBrush>
    <SolidColorBrush x:Key="SurfacePressedBrush">#111417</SolidColorBrush>
    <SolidColorBrush x:Key="SurfaceRaisedBrush">#14191E</SolidColorBrush>
    <SolidColorBrush x:Key="SelectionBackgroundBrush">#162737</SolidColorBrush>
    <SolidColorBrush x:Key="SelectionBorderBrush">#4AA3FF</SolidColorBrush>
    <SolidColorBrush x:Key="BorderBrushBase">#36414B</SolidColorBrush>
    <SolidColorBrush x:Key="FocusBorderBrush">#71B7FF</SolidColorBrush>
    <SolidColorBrush x:Key="PrimaryTextBrush">#E8EEF2</SolidColorBrush>
    <SolidColorBrush x:Key="SecondaryTextBrush">#A8B4BE</SolidColorBrush>
    <SolidColorBrush x:Key="MutedTextBrush">#7B8791</SolidColorBrush>
    <SolidColorBrush x:Key="PlaceholderTextBrush">#6E7982</SolidColorBrush>
    <SolidColorBrush x:Key="TitleBarButtonHoverBrush">#1A232C</SolidColorBrush>
    <SolidColorBrush x:Key="TitleBarCloseHoverBrush">#7A1F28</SolidColorBrush>
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource TerminalFont}" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource TerminalFont}" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style Selector="TextBlock.metaText">
    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style Selector="TextBlock.mutedText">
    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
  </Style>

  <Style Selector="TextBlock.titleBarText">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.footerStatusText">
    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <Style Selector="Border.sidebarSurface, Border.editorSurface, Border.sectionSurface">
    <Setter Property="Background" Value="{DynamicResource PaneBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushBase}" />
    <Setter Property="CornerRadius" Value="1" />
  </Style>

  <Style Selector="Border.titleBarSurface">
    <Setter Property="Background" Value="{DynamicResource PaneBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushBase}" />
  </Style>

  <Style Selector="Button">
    <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushBase}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="1" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="MinHeight" Value="30" />
    <Setter Property="FontFamily" Value="{DynamicResource TerminalFont}" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style Selector="Button:pointerover, Button:pressed">
    <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource FocusBorderBrush}" />
  </Style>

  <Style Selector="Button.secondaryButton">
    <Setter Property="Background" Value="{DynamicResource PaneBackgroundBrush}" />
  </Style>

  <Style Selector="Button.titleBarButton">
    <Setter Property="Background" Value="{DynamicResource PaneBackgroundBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinHeight" Value="30" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.titleBarButton:pointerover, Button.titleBarButton:pressed">
    <Setter Property="Background" Value="{DynamicResource TitleBarButtonHoverBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="Button.titleBarCloseButton:pointerover, Button.titleBarCloseButton:pressed">
    <Setter Property="Background" Value="{DynamicResource TitleBarCloseHoverBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushBase}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="1" />
    <Setter Property="Padding" Value="8,5" />
    <Setter Property="CaretBrush" Value="{DynamicResource PrimaryTextBrush}" />
    <Setter Property="SelectionBrush" Value="#2A4055" />
    <Setter Property="FontFamily" Value="{DynamicResource TerminalFont}" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style Selector="TextBox:pointerover, TextBox:focus, TextBox:focus-within">
    <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource FocusBorderBrush}" />
  </Style>

  <Style Selector="TextBox /template/ TextBlock.watermark">
    <Setter Property="Foreground" Value="{DynamicResource PlaceholderTextBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource TerminalFont}" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <Style Selector="TextBox.compactPlaceholder /template/ TextBlock.watermark">
    <Setter Property="FontSize" Value="9" />
  </Style>

  <Style Selector="TextBox.editorTextBox /template/ TextBlock.watermark">
    <Setter Property="FontSize" Value="10" />
  </Style>

  <Style Selector="TextBox:disabled">
    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
  </Style>

  <Style Selector="TextBox.fileRowEditor">
    <Setter Property="Padding" Value="4,1" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style Selector="TextBox.editorTextBox">
    <Setter Property="SelectionBrush" Value="#3E5368" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushBase}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="1" />
    <Setter Property="FontFamily" Value="{DynamicResource TerminalFont}" />
    <Setter Property="FontSize" Value="9" />
  </Style>

  <Style Selector="ComboBox:pointerover, ComboBox:focus">
    <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource FocusBorderBrush}" />
  </Style>

  <Style Selector="ComboBoxItem">
    <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource TerminalFont}" />
    <Setter Property="FontSize" Value="9" />
  </Style>

  <Style Selector="ComboBoxItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
  </Style>

  <Style Selector="ComboBoxItem:selected">
    <Setter Property="Background" Value="{DynamicResource SelectionBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
  </Style>

  <Style Selector="ContextMenu">
    <Setter Property="Background" Value="{DynamicResource PaneBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushBase}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="MenuItem">
    <Setter Property="Background" Value="{DynamicResource PaneBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource TerminalFont}" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <Style Selector="MenuItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource SelectionBackgroundBrush}" />
  </Style>

  <Style Selector="ListBox">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="ListBoxItem">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Border.fileRow">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="1" />
  </Style>

  <Style Selector="TextBlock.fileRowText">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
  </Style>

  <Style Selector="ListBoxItem:pointerover Border.fileRow">
    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushBase}" />
  </Style>

  <Style Selector="ListBoxItem:selected Border.fileRow">
    <Setter Property="Background" Value="{DynamicResource SelectionBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SelectionBorderBrush}" />
  </Style>

  <Style Selector="ListBoxItem:selected TextBlock.fileRowText">
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
  </Style>
</Styles>
