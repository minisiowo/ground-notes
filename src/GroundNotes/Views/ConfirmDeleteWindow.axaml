<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:GroundNotes.Views"
        x:Class="GroundNotes.Views.ConfirmDeleteWindow"
        Title="Confirm Delete"
        Width="420"
        Height="200"
        CanResize="False"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        KeyDown="OnWindowKeyDown"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*">
    <views:TitleBarControl Grid.Row="0"
                           Title="{Binding Title}"
                           TitleBarPointerPressed="OnTitleBarPointerPressed"
                           CloseRequested="OnTitleBarCloseRequested" />

    <Border Grid.Row="1" Classes="sectionSurface" Margin="12" Padding="14" BorderThickness="1">
      <Grid RowDefinitions="Auto,*,Auto">
        <TextBlock Text="{Binding Heading}" FontSize="{DynamicResource AppFontSizeLarge}" FontWeight="SemiBold" />
        <TextBlock Grid.Row="1"
                   Classes="metaText"
                   Margin="0,10,0,0"
                   TextWrapping="Wrap"
                   Text="{Binding Message}" />
        <StackPanel Grid.Row="2"
                    Margin="0,14,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
          <Button Classes="secondaryButton" Content="Cancel" Click="OnCancelClick" />
          <Button x:Name="DeleteButton" Content="{Binding ConfirmButtonText}" Click="OnDeleteClick" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
